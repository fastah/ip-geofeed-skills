{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Single Entry: Test Data (no limit)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/experimental/ip-geofeed",
            "args": [
                "${workspaceFolder}/experimental/ip-geofeed/testdata/sample_geofeed.csv"
            ],
            "cwd": "${workspaceFolder}/experimental/ip-geofeed"
        },
        {
            "name": "Single Entry: Test Data (with limit)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/experimental/ip-geofeed",
            "args": [
                "--limit-entries",
                "${input:entryLimit}",
                "${workspaceFolder}/experimental/ip-geofeed/testdata/sample_geofeed.csv"
            ],
            "cwd": "${workspaceFolder}/experimental/ip-geofeed"
        },
        {
            "name": "Single Entry: Custom File (no limit)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/experimental/ip-geofeed",
            "args": [
                "${input:csvFilePath}"
            ],
            "cwd": "${workspaceFolder}/experimental/ip-geofeed"
        },
        {
            "name": "Single Entry: Custom File (with limit)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/experimental/ip-geofeed",
            "args": [
                "--limit-entries",
                "${input:entryLimit}",
                "${input:csvFilePath}"
            ],
            "cwd": "${workspaceFolder}/experimental/ip-geofeed"
        },
        {
            "name": "Bulk Mode: Test Data (no limit)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/experimental/ip-geofeed",
            "args": [
                "--bulk",
                "${workspaceFolder}/experimental/ip-geofeed/testdata/publishers.json"
            ],
            "cwd": "${workspaceFolder}/experimental/ip-geofeed"
        },
        {
            "name": "Bulk Mode: Test Data (with limit)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/experimental/ip-geofeed",
            "args": [
                "--bulk",
                "--limit-entries",
                "${input:entryLimit}",
                "${workspaceFolder}/experimental/ip-geofeed/testdata/publishers.json"
            ],
            "cwd": "${workspaceFolder}/experimental/ip-geofeed"
        },
        {
            "name": "Bulk Mode: Custom File (no limit)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/experimental/ip-geofeed",
            "args": [
                "--bulk",
                "${input:bulkFilePath}"
            ],
            "cwd": "${workspaceFolder}/experimental/ip-geofeed"
        },
        {
            "name": "Bulk Mode: Custom File (with limit)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/experimental/ip-geofeed",
            "args": [
                "--bulk",
                "--limit-entries",
                "${input:entryLimit}",
                "${input:bulkFilePath}"
            ],
            "cwd": "${workspaceFolder}/experimental/ip-geofeed"
        }
    ],
    "inputs": [
        {
            "id": "entryLimit",
            "type": "promptString",
            "description": "Enter the limit for number of entries to validate",
            "default": "100"
        },
        {
            "id": "csvFilePath",
            "type": "promptString",
            "description": "Enter the path to the CSV file or URL",
            "default": "${workspaceFolder}/experimental/ip-geofeed/testdata/sample_geofeed.csv"
        },
        {
            "id": "bulkFilePath",
            "type": "promptString",
            "description": "Enter the path to the file containing URLs for bulk validation",
            "default": "${workspaceFolder}/experimental/ip-geofeed/testdata/publishers.json"
        }
    ]
}
